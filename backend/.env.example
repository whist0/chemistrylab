# Порт HTTP-сервера (если 3000 занят — поставьте 3001 и обновите window.API_URL на фронте)
PORT=3000

# Разрешённые origin для CORS (без пути к репозиторию — только схема+хост).
# Несколько значений через запятую.
# GitHub Pages: https://whist0.github.io
# Локально: http://127.0.0.1:5500
CORS_ORIGIN=http://127.0.0.1:5500
