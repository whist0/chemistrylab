# Порт HTTP-сервера (если 3000 занят — поставьте 3001 и обновите window.API_URL на фронте)
PORT=3000

# Разрешённый origin для CORS (URL вашего статического сайта).
# Локально: http://127.0.0.1:5500 или http://localhost:5500 (Live Server)
# На проде: https://ваш-логин.github.io или URL с Railway/Render
CORS_ORIGIN=http://127.0.0.1:5500
